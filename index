<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>The Bound Soul | Скачать игру для Windows</title>
    <style>
        :root { --primary: #72efdd; --bg: #0b0a0d; --card: #161625; --text: #ccc; }
        body { background-color: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; margin: 0; }
        
        header { background: #1a1a2e; padding: 20px 50px; border-bottom: 3px solid var(--primary); display: flex; justify-content: space-between; }
        .logo { font-size: 24px; font-weight: bold; color: #fff; }
        
        .container { max-width: 1100px; margin: 30px auto; display: flex; gap: 30px; padding: 0 20px; }
        .main-content { flex: 3; }
        .sidebar { flex: 1; }

        .game-info { background: var(--card); padding: 25px; border-radius: 10px; display: flex; gap: 20px; margin-bottom: 20px; }
        .icon { width: 150px; height: 150px; object-fit: cover; border: 2px solid var(--primary); border-radius: 10px; }
        .download-btn { display: block; background: var(--primary); color: #000; padding: 15px; text-align: center; text-decoration: none; font-weight: bold; border-radius: 5px; margin-top: 15px; }

        .section { background: var(--card); padding: 20px; border-radius: 10px; margin-bottom: 20px; text-align: left; }
        h3 { margin-top: 0; color: #fff; }
        
        .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .gallery img { width: 100%; border-radius: 5px; border: 1px solid #333; }
        
        /* Стили для реальных комментариев */
        .comment-item { background: #201d2b; padding: 12px; border-radius: 6px; margin-bottom: 10px; border-left: 3px solid var(--primary); }
        .comment-item strong { color: #fff; display: block; margin-bottom: 5px; }
        .comment-item small { color: #666; display: block; margin-top: 5px; }
        
        .comment-form input, .comment-form textarea { 
            width: 100%; background: #25202e; border: 1px solid #3d3550; 
            color: #fff; padding: 10px; border-radius: 5px; margin-bottom: 10px; box-sizing: border-box;
        }
        .comment-form button { background: var(--primary); color: #000; border: none; padding: 10px 20px; font-weight: bold; border-radius: 4px; cursor: pointer; }
        
        footer { text-align: center; padding: 40px; color: #555; }
    </style>
</head>
<body>

<header>
    <div class="logo">GameHub Store</div>
    <div>Главная / Игры / The Bound Soul</div>
</header>

<div class="container">
    <div class="main-content">
        <div class="game-info">
            <img src="assets/GameIcon.png" class="icon" alt="Иконка игры">
            <div style="text-align: left;">
                <h1 style="margin: 0; color: #fff;">The Bound Soul</h1>
                <p><strong>Версия:</strong> 1.0 | <strong>Вес:</strong> 30 Мб | <strong>Скачиваний:</strong> <span id="download-count">0</span></p>
                <p>Мрачное приключение в глубинах подземелья.</p>
                <a href="TheBoundSoul.zip" class="download-btn" id="download-link">СКАЧАТЬ ИГРУ (30 Мб)</a>
            </div>
        </div>

        <div class="section">
            <h3>Скриншоты</h3>
            <div class="gallery">
                <img src="assets/img1.png" alt="Скриншот">
                <img src="assets/img2.png" alt="Скриншот">
                <img src="assets/img3.png" alt="Скриншот">
                <img src="assets/img4.png" alt="Скриншот">
                <img src="assets/img5.png" alt="Скриншот">
            </div>
        </div>

        <!-- Живые комментарии -->
        <div class="section">
            <h3>Отзывы игроков</h3>
            <div id="comments-container">
                <!-- Сюда JavaScript будет добавлять новые комментарии -->
            </div>

            <h4 style="color:#fff; margin-top:20px;">Оставить отзыв</h4>
            <div class="comment-form">
                <input type="text" id="username" placeholder="Твой никнейм" required>
                <textarea id="comment-text" placeholder="Напиши, что думаешь об игре..." required></textarea>
                <button id="submit-comment">Отправить</button>
            </div>
        </div>
    </div>

    <div class="sidebar">
        <div class="section">
            <h3>Системные требования</h3>
            <p><strong>ОС:</strong> Windows 10/11</p>
            <p><strong>Память:</strong> 4 GB RAM</p>
        </div>
    </div>
</div>

<footer>
    <p>GameHub © 2026. Портал для скачивания инди-игр.</p>
</footer>

<!-- Логика работы счетчиков и сохранения -->
<script>
    // --- РАБОТА СО СКАЧИВАНИЯМИ ---
    let downloads = localStorage.getItem('tbs_downloads') ? parseInt(localStorage.getItem('tbs_downloads')) : 0;
    const downloadCountEl = document.getElementById('download-count');
    const downloadLink = document.getElementById('download-link');

    downloadCountEl.textContent = downloads;

    downloadLink.addEventListener('click', () => {
        downloads += 1;
        localStorage.setItem('tbs_downloads', downloads);
        downloadCountEl.textContent = downloads;
    });

    // --- РАБОТА С КОММЕНТАРИЯМИ ---
    const commentsContainer = document.getElementById('comments-container');
    const usernameInput = document.getElementById('username');
    const commentTextInput = document.getElementById('comment-text');
    const submitBtn = document.getElementById('submit-comment');

    let comments = localStorage.getItem('tbs_comments') ? JSON.parse(localStorage.getItem('tbs_comments')) : [];

    function renderComments() {
        commentsContainer.innerHTML = '';
        if (comments.length === 0) {
            commentsContainer.innerHTML = '<p id="no-comments"><i>Пока отзывов нет. Будь первым!</i></p>';
            return;
        }
        comments.forEach(c => {
            const div = document.createElement('div');
            div.className = 'comment-item';
            div.innerHTML = `<strong>${c.name}</strong><div>${c.text}</div><small>${c.date}</small>`;
            commentsContainer.appendChild(div);
        });
    }

    submitBtn.addEventListener('click', () => {
        const name = usernameInput.value.trim();
        const text = commentTextInput.value.trim();

        if (name && text) {
            const newComment = {
                name: name,
                text: text,
                date: new Date().toLocaleString('ru-RU')
            };
            comments.push(newComment);
            localStorage.setItem('tbs_comments', JSON.stringify(comments));
            renderComments();
            
            // Очищаем форму
            usernameInput.value = '';
            commentTextInput.value = '';
        } else {
            alert('Пожалуйста, заполни оба поля!');
        }
    });

    // Показываем старые комменты при загрузке
    renderComments();
</script>

</body>
</html>
